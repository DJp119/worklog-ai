# ============================================
# Worklog AI Server Environment Variables
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Database (Supabase Postgres - for data only, NOT auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# Email Service (Brevo - free tier supports 300 emails/day)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=noreply@yourdomain.com
BREVO_FROM_NAME=Worklog AI

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI (Mistral AI)
# Get API key at: https://console.mistral.ai/api-keys/
# See quotas at: https://docs.mistral.ai/platform/quotas/
MISTRAL_API_KEY=your-mistral-api-key-here

# PostHog Analytics (Server-side)
# Get your key from: https://app.posthog.com/settings/projects
# Use the SAME project token as the client (phc_...)
POSTHOG_API_KEY=phc_your-project-token-here
POSTHOG_HOST=https://us.i.posthog.com

# Legacy support (backward compatible)
# POSTHOG_KEY=your-legacy-posthog-key

