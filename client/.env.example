# Supabase Configuration (Database only, NOT auth)
VITE_SUPABASE_URL=https://your-project.supabase.co

# API Configuration
VITE_API_URL=http://localhost:3001

# For production deployment, update VITE_API_URL to your Render backend URL
# Example: VITE_API_URL=https://worklog-ai-server.onrender.com

# PostHog Analytics ( جديد - Fresh Setup)
# Get your key from: https://app.posthog.com/settings/projects
VITE_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_your-project-token-here
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Legacy support (backward compatible)
# VITE_POSTHOG_KEY=your-posthog-project-api-key
# VITE_POSTHOG_HOST=https://us.i.posthog.com
